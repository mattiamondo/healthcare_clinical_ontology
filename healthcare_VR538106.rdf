    </owl:Class>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#PolypharmacyPatient -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#PolypharmacyPatient">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Patient"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#takesTreatment"/>
                        <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">3</owl:minQualifiedCardinality>
                        <owl:onClass rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Drug"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Patient"/>
        <rdfs:comment>A patient taking at least three distinct drugs.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Prescription -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Prescription"/>
    


