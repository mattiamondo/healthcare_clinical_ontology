    </owl:Class>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Patient -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Patient">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Person"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#PediatricPatient -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#PediatricPatient">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Patient"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#age"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:maxExclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">18</xsd:maxExclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Patient"/>
        <rdfs:comment>A patient younger than 18.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Person -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Person"/>
    


