                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Clinician"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#hasSpecialty"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onClass rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Specialty"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Clinician"/>
        <rdfs:comment>A clinician with exactly one specialty.</rdfs:comment>
    </owl:Class>
    


