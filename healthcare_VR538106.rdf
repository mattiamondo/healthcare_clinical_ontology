<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology/"
     xml:base="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:healthcare-clinical-ontology="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology">
        <rdfs:comment>A clinical and hospital ontology modelling patients, diseases, treatments, staff, facilities and care encounters, with reasoning support for patient risks.</rdfs:comment>
        <owl:versionInfo>1.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#administeredBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#administeredBy">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Treatment"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#MedicalStaff"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#affectsBodySystem -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#affectsBodySystem">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Disease"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#BodySystem"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#assignedToVehicle -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#assignedToVehicle">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#HealthcareActor"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Vehicle"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#causedBySubstance -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#causedBySubstance">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#causesAllergy"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Allergy"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Substance"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#causesAllergy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#causesAllergy">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Substance"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Allergy"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#contains -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#contains">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#isContainedIn"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Drug"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Substance"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#coversBodySystem -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#coversBodySystem">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Specialty"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#BodySystem"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#diagnosedBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#diagnosedBy">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#diagnoses"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Patient"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Clinician"/>
        <rdfs:comment>Each diagnosis is attributed to a single clinician.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#diagnoses -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#diagnoses">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Clinician"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Patient"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#dispatchedFor -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#dispatchedFor">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Vehicle"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#EmergencyEncounter"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#encounterClinician -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#encounterClinician">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Encounter"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Clinician"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#evidenceOfSymptom -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#evidenceOfSymptom">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Encounter"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Symptom"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#hasAllergy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#hasAllergy">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Patient"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Allergy"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#hasCondition -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#hasCondition">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#isConditionOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Patient"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Disease"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#hasEmergencySymptom -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#hasEmergencySymptom">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#evidenceOfSymptom"/>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#EmergencyEncounter"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Symptom"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#hasEncounter -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#hasEncounter">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#hasPatient"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Patient"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Encounter"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#hasGender -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#hasGender">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Person"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Gender"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#hasObservedSymptom -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#hasObservedSymptom">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Patient"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Symptom"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#hasEncounter"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#evidenceOfSymptom"/>
        </owl:propertyChainAxiom>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#hasPatient -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#hasPatient">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Encounter"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Patient"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#hasSpecialty -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#hasSpecialty">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Clinician"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Specialty"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#hasSymptom -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#hasSymptom">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#isSymptomOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Disease"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Symptom"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#hasTriageCode -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#hasTriageCode">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#EmergencyEncounter"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#TriageCode"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#interactsWith -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#interactsWith">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Substance"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Substance"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#isConditionOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#isConditionOf">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Disease"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Patient"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#isContainedIn -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#isContainedIn">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Substance"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Drug"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#isLocatedIn -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#isLocatedIn">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#FacilityZone"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#HealthcareFacility"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#isSymptomOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#isSymptomOf">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Symptom"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Disease"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#managedByStaff -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#managedByStaff">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#managesEncounter"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Encounter"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#AdministrativeStaff"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#managesEncounter -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#managesEncounter">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#AdministrativeStaff"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Encounter"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#occursAt -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#occursAt">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Encounter"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#FacilityZone"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#prescribedByClinician -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#prescribedByClinician">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Prescription"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Clinician"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#prescribedFor -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#prescribedFor">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Prescription"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Patient"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#prescribedTo -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#prescribedTo">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#takesTreatment"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Treatment"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Patient"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#prescribesDrug -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#prescribesDrug">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Prescription"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Drug"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#takesTreatment -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#takesTreatment">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Patient"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Treatment"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#treatedBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#treatedBy">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Disease"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Treatment"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#treatsBodySystem -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#treatsBodySystem">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Clinician"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#BodySystem"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#hasSpecialty"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#coversBodySystem"/>
        </owl:propertyChainAxiom>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#undergoesProcedure -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#undergoesProcedure">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Patient"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Procedure"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#worksIn -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#worksIn">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#HealthcareActor"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#FacilityZone"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#age -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#age">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#dosage -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#dosage">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Drug"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#durationMonths -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#durationMonths">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Disease"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#personName -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#personName">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#prescriptionDate -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#prescriptionDate">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Prescription"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#priorityLevel -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#priorityLevel">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#TriageCode"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#severityLevel -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#severityLevel">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Symptom"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#stayDurationHours -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#stayDurationHours">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Encounter"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#AcuteDisease -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#AcuteDisease">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Disease"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#ChronicDisease"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#AdministrativeStaff -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#AdministrativeStaff">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#NonMedicalStaff"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#SupportStaff"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Allergy -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Allergy"/>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Ambulance -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Ambulance">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Vehicle"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#MedicalHelicopter"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Antibiotic -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Antibiotic">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Drug"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#contains"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#AntibioticSubstance"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Drug"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#AntibioticSubstance -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#AntibioticSubstance">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Substance"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#BodySystem -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#BodySystem"/>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#ChronicDisease -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#ChronicDisease">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Disease"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Clinic -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Clinic">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#HealthcareFacility"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#ClinicalWard -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#ClinicalWard">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#FacilityZone"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#SupportZone"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Clinician -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Clinician">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#MedicalStaff"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#CriticalEmergency -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#CriticalEmergency">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#EmergencyEncounter"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#hasEmergencySymptom"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Symptom"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#severityLevel"/>
                                        <owl:someValuesFrom>
                                            <rdfs:Datatype>
                                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
                                                <owl:withRestrictions rdf:parseType="Collection">
                                                    <rdf:Description>
                                                        <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">9</xsd:minInclusive>
                                                    </rdf:Description>
                                                </owl:withRestrictions>
                                            </rdfs:Datatype>
                                        </owl:someValuesFrom>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#EmergencyEncounter"/>
        <rdfs:comment>An emergency admission with at least one high-severity symptom (severity ≥ 9).</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#DiagnosticProcedure -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#DiagnosticProcedure">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Procedure"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#TherapeuticProcedure"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Disease -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Disease"/>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Drug -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Drug">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Treatment"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#contains"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Substance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Procedure"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Therapy"/>
        <rdfs:comment>Each drug is modelled with a single active substance.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#ElderlyPatient -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#ElderlyPatient">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Patient"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#age"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">65</xsd:minInclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Patient"/>
        <rdfs:comment>A patient aged 65 or older.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#EmergencyEncounter -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#EmergencyEncounter">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Encounter"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Encounter -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Encounter"/>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#FacilityZone -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#FacilityZone">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#isLocatedIn"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#HealthcareFacility"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#FollowUpVisit -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#FollowUpVisit">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Encounter"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Gender -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Gender">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#gender_Female"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#gender_Male"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#GeneralPractitioner -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#GeneralPractitioner">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Clinician"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Specialist"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#GeneticDisease -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#GeneticDisease">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Disease"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#InfectiousDisease"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#HealthcareActor -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#HealthcareActor">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Person"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#HealthcareFacility -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#HealthcareFacility"/>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#HighRiskPatient -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#HighRiskPatient">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Patient"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#hasCondition"/>
                        <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:minQualifiedCardinality>
                        <owl:onClass rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#ChronicDisease"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Patient"/>
        <rdfs:comment>A patient with at least two distinct chronic conditions.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Hospital -->

    <owl:Class rdf:about="http://www.semanticweb.org/mattiamondo/ontologies/2026/5/healthcare-clinical-ontology#Hospital">
